{% extends 'structure/base.html.twig' %}

{% set currentPage = 'Page d\'administration des utilisateurs' %}
{% set currentRoute = app.request.attributes.get('_route') %}

{% block pageTitle %}
	{{ parent() }}
	-
	{{ currentPage }}
{% endblock %}


{% block content %}
	{% include 'structure/header.html.twig' with {'currentRoute': currentRoute, 'breadcrumbs': [
		{ 'link': path('app_home'), 'name': 'Accueil' },
		{ 'link': path('app_user_list'), 'name': 'Gestion des utilisateurs' }
	]} 
	%}
	<section class="section">
	{% include 'structure/title.html.twig' with {'currentPage': currentPage} %}

    <h2>Liste des utilisateurs</h1>

	{% include 'structure/notifications.html.twig' %}
    <a href="{{ path('app_user_create') }}" class="btn btn-secondary">Créer un utilisateur</a>
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Prénom</th>
                <th>Email</th>
                <th>Téléphone</th>
                <th>Rôles</th>
                <th>Vérification</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.lastName }}</td>
                <td>{{ user.firstName }}</td>
				<td>{{ user.email }}</td>
				<td>{{ user.phone }}</td>
				<td>{{ user.roles | join(', ') }}</td>
                <td>{{ user.isVerified ? '✔️' : '❌' }}</td>
				<td>
					<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-secondary">Éditer</a>
					<form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" onsubmit="return confirm('Êtes vous certain de vouloir supprimer l'utilisateur {{ user.id }} ?')">
						<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
						<button class="btn btn-danger">Supprimer</button>
					</form>
				</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">Aucun utilisateur trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
	</section>
	{% include 'structure/footer.html.twig' %}
{% endblock %}
