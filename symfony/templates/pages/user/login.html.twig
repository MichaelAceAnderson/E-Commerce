{% extends 'structure/base.html.twig' %}

{% set currentPage = 'Connexion' %}
{% set currentRoute = app.request.attributes.get('_route') %}

{% block pageTitle %}
	{{ parent() }}
	-
	{{ currentPage }}
{% endblock %}


{% block content %}
	{% include 'structure/header.html.twig' with {'currentRoute': currentRoute, 'breadcrumbs': [
		{ 'link': path('app_home'), 'name': 'Accueil' },
		{ 'link': path(currentRoute), 'name': currentPage }
	]} 
	%}
	<section class="section">
	{% include 'structure/title.html.twig' with {'currentPage': currentPage} %}
	{% include 'structure/notifications.html.twig' %}

		{% if app.user %}
			<div class="notification info">Vous êtes déjà connecté ! Cliquez <a href="{{ path('app_user_show') }}">ici</a> pour consulter votre profil.</div>
		{% else %}
		<div class="login">
			{{ form_start(loginForm) }}
				{{ form_row(loginForm.email, {'value': last_username ?? ''}) }}
				{{ form_row(loginForm.password) }}
				{{ form_widget(loginForm.submit) }}
			{{ form_end(loginForm) }}
			<p>Vous n'avez pas de compte ? <a href="{{ path('app_user_register') }}">Inscrivez-vous</a></p>
		</div>
		{% endif %}
	</section>
{% endblock %}
