{% extends 'structure/base.html.twig' %}

{% set currentPage = 'Mes commandes' %}
{% set currentRoute = app.request.attributes.get('_route') %}

{% block pageTitle %}
	{{ parent() }}
	-
	{{ currentPage }}
{% endblock %}

{% block content %}
	{% include 'structure/header.html.twig' with {'currentRoute': currentRoute, 'breadcrumbs': [
	{ 'link': path('app_home'), 'name': 'Accueil' },
	{ 'link': path('app_user_show'), 'name': 'Mon compte' },
	{ 'link': path(currentRoute), 'name': currentPage }
]} %}

	<section class="section center">
		{% include 'structure/title.html.twig' with {'currentPage': currentPage} %}
		{% include 'structure/notifications.html.twig' %}
		{% if orders is defined %}
			<table class="table">
				<thead>
					<tr>
						<th>Numéro</th>
						<th>Date</th>
						<th>Statut</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for order in orders %}
						<tr>
							<td>{{ order.number }}</td>
							<td>{{ order.orderDate|date('d/m/Y') }}</td>
							<td>{{ order.isValidated ? '✔️' : '❌' }}</td>
							<td>
								<a href="{{ path('app_order_show', {'id': order.id}) }}" class="btn btn-secondary">Voir</a>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="4">Vous n'avez aucune commande associée à ce compte !</td>
					{% endfor %}
				</tbody>
			</table>
		{% else %}
			<p class="notification info">Vous n'avez aucune commande !</p>
		{% endif %}
	</section>

	{% include 'structure/footer.html.twig' %}
{% endblock %}
